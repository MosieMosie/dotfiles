#taskbar button image {
    min-width: 0;
    min-height: 0;
    padding: 0;
    opacity: 0;
}

/* ── Idle Inhibitor (teal) ──────────────────────────────────── */
#idle_inhibitor {
    background: #B5E8E0;
    padding-right: 14px;
    color: #161320;
}

#idle_inhibitor.activated {
    background: @yellow;
}

/* ── PulseAudio Slider (maroon) ─────────────────────────────── */
#pulseaudio-slider {
    color: #1A1826;
    background: #E8A2AF;
    min-width: 60px;
    padding: 0 8px;
}

/* ── PulseAudio Slider — proper trough/handle styling ──────── */
#pulseaudio-slider {
    background: transparent;   /* no pill background */
    min-width: 80px;
    padding: 0 4px;
}

#pulseaudio-slider slider {
    min-width: 12px;
    min-height: 12px;
    border-radius: 50%;
    background: #E8A2AF;
    border: 2px solid #161320;
}

#pulseaudio-slider trough {
    min-height: 4px;
    border-radius: 4px;
    background: @surface1;
}

#pulseaudio-slider highlight {
    min-height: 4px;
    border-radius: 4px;
    background: #E8A2AF;
}
/* ── PulseAudio (rosewater) ─────────────────────────────────── */
#pulseaudio {
    background: #F5E0DC;
    color: #1A1826;
    min-width: 60px;
}

#pulseaudio.muted {
    background: @surface1;
    color: @subtext0;
}

#pulseaudio.bluetooth {
    background: @blue;
    color: @crust;
}

/* ── Network (lavender) ─────────────────────────────────────── */
#network {
    background: #CBA6F7;
    color: #161320;
    padding-right: 14px;
}

#network.disconnected {
    background: @red;
    color: @crust;
}

/* ── Language (green) ───────────────────────────────────────── */
#language {
    background: #A6E3A1;
    color: #161320;
    padding-right: 14px;
}

/* ── Power button ───────────────────────────────────────────── */
#custom-power {
    background: #161320;
    color: @red;
    font-size: 15px;
    margin-right: 5px;
    padding: 0 14px;
    border-radius: 10px;
    transition: background 0.2s ease, color 0.2s ease;
}

#custom-power:hover {
    background: @red;
    color: @crust;
}

/* ── Tooltip ────────────────────────────────────────────────── */
tooltip {
    background: @mantle;
    border: 1px solid @surface1;
    border-radius: 10px;
    color: @text;
    padding: 6px;
}

tooltip label {
    color: @text;
}

/* ── Blink animation ────────────────────────────────────────── */
@keyframes blink {
    to {
        background-color: @red;
        color: @crust;
    }
}
