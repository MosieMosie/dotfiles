/* ============================================================
   Waybar — Catppuccin Mocha — Merged Theme
   ~/.config/waybar/style.css
   ============================================================ */

/* ── Catppuccin Mocha Palette ──────────────────────────────── */
@define-color base      #1e1e2e;
@define-color mantle    #181825;
@define-color crust     #11111b;
@define-color surface0  #313244;
@define-color surface1  #45475a;
@define-color surface2  #585b70;
@define-color overlay1  #7f849c;
@define-color subtext0  #a6adc8;
@define-color text      #cdd6f4;

/* Accent colors */
@define-color rosewater #f5e0dc;
@define-color flamingo  #f2cdcd;
@define-color pink      #f5c2e7;
@define-color mauve     #cba6f7;
@define-color red       #f38ba8;
@define-color maroon    #eba0ac;
@define-color peach     #fab387;
@define-color yellow    #f9e2af;
@define-color green     #a6e3a1;
@define-color teal      #94e2d5;
@define-color sky       #89dceb;
@define-color sapphire  #74c7ec;
@define-color blue      #89b4fa;
@define-color lavender  #b4befe;

/* ── Global Reset ───────────────────────────────────────────── */
* {
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 13px;
    font-weight: 500;
    border: none;
    border-radius: 0;
    min-height: 0;
}

/* ── Bar background ─────────────────────────────────────────── */
window#waybar {
    background: transparent;
    color: @text;
}

window#waybar.hidden {
    opacity: 0.2;
}

/* ── All visible modules — shared base ──────────────────────── */
#custom-archicon,
#clock,
#cpu,
#memory,
#disk,
#temperature,
#idle_inhibitor,
#pulseaudio,
#pulseaudio-slider,
#network,
#language,
#custom-power {
    color: #161320;
    margin-top: 6px;
    margin-bottom: 6px;
    padding-left: 12px;
    padding-right: 12px;
    transition: none;
}

/* ── Left caps (rounded left edge) ─────────────────────────── */
#custom-archicon,
#cpu,
#idle_inhibitor {
    margin-left: 5px;
    border-top-left-radius: 10px;
    border-bottom-left-radius: 10px;
}

/* ── Right caps (rounded right edge) ───────────────────────── */
#clock,
#temperature,
#language {
    margin-right: 5px;
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
}

/* ── Arch Icon ──────────────────────────────────────────────── */
#custom-archicon {
    font-size: 18px;
    color: @blue;
    background: #161320;
    padding-right: 18px;
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
}

#custom-archicon:hover {
    color: @lavender;
}

/* ── Clock (green) ──────────────────────────────────────────── */
#clock {
    background: #ABE9B3;
    font-weight: 700;
}

/* ── CPU (blue) ─────────────────────────────────────────────── */
#cpu {
    background: #96CDFB;
}

#cpu.high {
    background: @red;
    color: @crust;
    animation: blink 0.5s step-end infinite alternate;
}

/* ── Memory (mauve) ─────────────────────────────────────────── */
#memory {
    background: #DDB6F2;
}

#memory.critical {
    background: @red;
    color: @crust;
}

/* ── Disk (pink) ────────────────────────────────────────────── */
#disk {
    background: #F5C2E7;
}

/* ── Temperature (peach) ────────────────────────────────────── */
#temperature {
    background: #F8BD96;
}

#temperature.critical {
    background: @red;
    color: @crust;
    animation: blink 0.5s step-end infinite alternate;
}

/* ── Workspaces ─────────────────────────────────────────────── */
#workspaces {
    background: rgba(30, 30, 46, 0.85);
    border-radius: 10px;
    margin: 6px 5px;
    padding: 0 6px;
    border: 1px solid @surface1;
}

#workspaces button {
    color: @teal;
    background: transparent;
    padding: 2px 8px;
    margin: 3px 2px;
    border-radius: 8px;
    border: 1px solid transparent;
    font-weight: 600;
    transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    min-width: 24px;
}

#workspaces button.occupied {
    color: @green;
}

#workspaces button.active {
    background: @mauve;
    color: @crust;
    border-color: @mauve;
    box-shadow: 0 0 8px rgba(203, 166, 247, 0.4);
    text-shadow: none;
}

#workspaces button:hover {
    color: @blue;
    border-color: @blue;
    background: @surface0;
}

#workspaces button.urgent {
    background: @red;
    color: @crust;
    animation: blink 0.8s step-end infinite alternate;
}

